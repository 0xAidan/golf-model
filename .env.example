# Data Golf API (required for round data, predictions, field updates)
# Get from: https://datagolf.com/api-access (Scratch Plus subscription)
DATAGOLF_API_KEY=your_datagolf_key_here

# OpenAI API (AI brain — analysis, decisions, memory)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# AI Brain provider selection (default: openai)
# Options: openai, anthropic, gemini
# AI_BRAIN_PROVIDER=openai

# Optional: OpenAI model override (default: gpt-4o)
# OPENAI_MODEL=gpt-4o-mini

# Anthropic API (optional — only if you want Claude instead of OpenAI)
# OpenAI handles everything including course screenshot extraction.
# Only set this if you prefer Claude as AI brain (AI_BRAIN_PROVIDER=anthropic).
# Get from: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=your_anthropic_key_here

# The Odds API (optional — for live market odds)
# Get from: https://the-odds-api.com/
# ODDS_API_KEY=your_odds_api_key_here

# Optional preferred-book label used as metadata alongside best-line odds (default: bet365).
# This does not gate matchup/value generation and does not limit UI filtering.
# PREFERRED_BOOK=bet365
# Deprecated (unused): legacy preferred-book-only gating toggle.
# PREFERRED_BOOK_ONLY=false

# Autoresearch guardrails: set to "loose" to allow more candidates to become promotable
# (lower min_bets, allow more CLV/calibration/drawdown regression). Use for exploratory runs.
# AUTORESEARCH_GUARDRAIL_MODE=loose
